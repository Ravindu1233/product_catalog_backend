Options -Indexes
RewriteEngine On

# Deny direct browser access to application internals.
RewriteRule ^(app|config|database)/ - [F,L]
RewriteRule \.(sql|md)$ - [F,L]

# Serve public assets from /public/assets when requested as /assets.
RewriteCond %{REQUEST_URI} ^/assets/
RewriteRule ^assets/(.*)$ public/assets/$1 [L]

# Route application requests through the front controller.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
